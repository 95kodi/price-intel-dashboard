{
  "name": "price-intel-agent",
  "version": "0.2.0",
  "private": true,
  "description": "Desktop scraper agent for the Price Intel dashboard. Runs price scans from a residential IP and pushes results to the backend API.",
  "author": "95kodi",
  "main": "dist/main.cjs",
  "bin": "dist/agent.cjs",
  "pkg": {
    "assets": [
      "browsers.json",
      "package.json"
    ],
    "targets": [
      "node22-win-x64"
    ]
  },
  "build": {
    "appId": "co.gogizmo.priceintel.agent",
    "productName": "Price Intel Agent",
    "asar": true,
    "files": [
      "dist/main.cjs",
      "dist/preload.cjs",
      "ui/**",
      "browsers.json",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "portable",
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "price-intel-agent.exe"
    }
  },
  "scripts": {
    "bundle": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=cjs --external:chromium-bidi/* --external:@sparticuz/chromium --outfile=dist/agent.cjs && node -e \"fs.copyFileSync('node_modules/playwright-core/browsers.json', 'browsers.json')\"",
    "bundle:app": "esbuild electron/main.ts --bundle --platform=node --target=node20 --format=cjs --external:electron --external:chromium-bidi/* --external:@sparticuz/chromium --outfile=dist/main.cjs && esbuild electron/preload.ts --bundle --platform=node --format=cjs --external:electron --outfile=dist/preload.cjs && node -e \"fs.copyFileSync('node_modules/playwright-core/browsers.json', 'browsers.json')\"",
    "start": "npm run bundle && node dist/agent.cjs",
    "app:dev": "npm run bundle:app && electron dist/main.cjs",
    "build:cli": "npm run bundle && pkg . --output dist/price-intel-agent.exe",
    "build:app": "npm run bundle:app && electron-builder --win"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.3.2",
    "axios": "^1.18.1",
    "electron": "^37.0.0",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.25.0",
    "playwright-core": "^1.61.1"
  }
}
